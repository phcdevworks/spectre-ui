---
import type { IconBoxProps } from "./IconBox.types";
import {
  paddingMap,
  roundedMap,
  shadowMap,
  containerVariantMap,
  iconSizeMap,
  iconColorMap,
} from "../utils/class-maps";

export type { IconBoxProps as Props };

const {
  padding = "md",
  rounded = "md",
  shadow = "sm",
  variant = "neutral",
  border = true,
  icon,
  iconPosition = "top",
  iconSize = "md",
  title,
  description,
  align = "left",
  class: className,
  id,
  "data-track": dataTrack,
  ...rest
} = Astro.props as IconBoxProps;

// Layout classes based on icon position
const layoutClass =
  iconPosition === "top" || iconPosition === "bottom" ? "flex flex-col" : "flex flex-row";

const alignClass =
  align === "center"
    ? "items-center text-center"
    : align === "right"
      ? "items-end text-right"
      : "items-start text-left";

const gapClass = iconPosition === "top" || iconPosition === "bottom" ? "gap-3" : "gap-4";
---

<div
  class:list={[
    "spectre-icon-box",
    layoutClass,
    alignClass,
    gapClass,
    paddingMap[padding],
    roundedMap[rounded],
    shadowMap[shadow],
    containerVariantMap[variant],
    { border: border },
    className,
  ]}
  id={id}
  data-track={dataTrack}
  {...rest}
>
  {
    icon && iconPosition !== "bottom" && iconPosition !== "right" && (
      <div
        class:list={[
          "spectre-icon-box__icon shrink-0",
          iconSizeMap[iconSize],
          iconColorMap[variant],
        ]}
        set:html={icon}
      />
    )
  }

  <div class="spectre-icon-box__content flex-1">
    {title && <h4 class="font-semibold leading-tight">{title}</h4>}
    {description && <p class="mt-1 text-sm opacity-90">{description}</p>}
    {
      Astro.slots.has("default") && (
        <div class:list={[{ "mt-2": title || description }]}>
          <slot />
        </div>
      )
    }
  </div>

  {
    icon && (iconPosition === "bottom" || iconPosition === "right") && (
      <div
        class:list={[
          "spectre-icon-box__icon shrink-0",
          iconSizeMap[iconSize],
          iconColorMap[variant],
        ]}
        set:html={icon}
      />
    )
  }
</div>
