---
import type { ButtonProps } from "./Button.types";
import { buttonSizeMap, buttonIconSizeMap, buttonVariantMap } from "../utils/class-maps";

export type { ButtonProps as Props };

const {
  variant = "primary",
  size = "md",
  type = "button",
  disabled = false,
  loading = false,
  href,
  target,
  rel,
  fullWidth = false,
  iconOnly = false,
  icon,
  iconPosition = "left",
  iconSize,
  class: className,
  id,
  "data-track": dataTrack,
  "data-event": dataEvent,
  "aria-label": ariaLabel,
  ...rest
} = Astro.props as ButtonProps;

const Component = href ? "a" : "button";
const componentProps = href
  ? { href, target, rel: rel || (target === "_blank" ? "noopener noreferrer" : undefined) }
  : { type, disabled: disabled || loading };
---

<Component
  class:list={[
    "spectre-button",
    "inline-flex items-center justify-center",
    "font-medium rounded-md",
    "transition-colors duration-200",
    "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2",
    "disabled:cursor-not-allowed disabled:opacity-60",
    buttonSizeMap[size],
    buttonVariantMap[variant],
    { "w-full": fullWidth },
    { "aspect-square": iconOnly },
    { "cursor-wait": loading },
    className,
  ]}
  id={id}
  data-track={dataTrack}
  data-event={dataEvent}
  aria-label={ariaLabel || (iconOnly ? "Button" : undefined)}
  aria-busy={loading}
  {...componentProps}
  {...rest}
>
  {
    loading && (
      <svg
        class:list={["animate-spin", buttonIconSizeMap[size]]}
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
      >
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
        <path
          class="opacity-75"
          fill="currentColor"
          d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
        />
      </svg>
    )
  }

  {
    !loading && icon && iconPosition === "left" && (
      <span
        class:list={["spectre-button__icon", buttonIconSizeMap[iconSize || size]]}
        set:html={icon}
      />
    )
  }

  {!iconOnly && <slot />}

  {
    !loading && icon && iconPosition === "right" && (
      <span
        class:list={["spectre-button__icon", buttonIconSizeMap[iconSize || size]]}
        set:html={icon}
      />
    )
  }
</Component>
