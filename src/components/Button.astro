---
import type { SpectreButtonProps } from "./button.types";

const {
  label = "Button",
  variant = "primary",
  type = "button",
} = Astro.props as SpectreButtonProps;
---

<button type={type} class={`spectre-btn spectre-btn--${variant}`}>
  <slot>{label}</slot>
</button>

<style>
  :root {
    --spectre-color-primary: #6366f1;
    --spectre-color-secondary: #0ea5e9;
    --spectre-color-text: #ffffff;
    --spectre-radius-base: 0.625rem;
    --spectre-shadow-elevated: 0 20px 40px -15px rgba(99, 102, 241, 0.35);
  }

  button {
    border: none;
    cursor: pointer;
    font: inherit;
  }

  .spectre-btn {
    align-items: center;
    border-radius: var(--spectre-radius-base);
    display: inline-flex;
    font-weight: 600;
    gap: 0.5rem;
    justify-content: center;
    line-height: 1;
    padding: 0.75rem 1.5rem;
    transition:
      transform 150ms ease,
      box-shadow 200ms ease;
  }

  .spectre-btn:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--spectre-color-primary) 65%, white);
    outline-offset: 3px;
  }

  .spectre-btn:active {
    transform: translateY(1px);
  }

  .spectre-btn--primary {
    background: linear-gradient(
      135deg,
      var(--spectre-color-primary),
      var(--spectre-color-secondary)
    );
    box-shadow: var(--spectre-shadow-elevated);
    color: var(--spectre-color-text);
  }

  .spectre-btn--secondary {
    background: color-mix(in srgb, var(--spectre-color-secondary) 82%, white);
    color: #0f172a;
  }

  .spectre-btn--ghost {
    background: transparent;
    border: 1px solid color-mix(in srgb, var(--spectre-color-primary) 30%, white);
    color: var(--spectre-color-primary);
  }

  .spectre-btn:hover {
    filter: brightness(1.02);
  }
</style>
