---
import type { CardProps } from "./Card.types";
import { paddingMap, roundedMap, shadowMap, containerVariantMap } from "../utils/class-maps";

export type { CardProps as Props };

const {
  padding = "lg",
  rounded = "lg",
  shadow = "md",
  variant = "neutral",
  border = false,
  title,
  subtitle,
  hoverable = false,
  class: className,
  id,
  "data-track": dataTrack,
  ...rest
} = Astro.props as CardProps;
---

<div
  class:list={[
    "spectre-card",
    paddingMap[padding],
    roundedMap[rounded],
    shadowMap[shadow],
    containerVariantMap[variant],
    { border: border },
    { "spectre-card--hoverable": hoverable },
    className,
  ]}
  id={id}
  data-track={dataTrack}
  {...rest}
>
  {
    (title || subtitle || Astro.slots.has("header")) && (
      <div class="spectre-card__header mb-4">
        {Astro.slots.has("header") ? (
          <slot name="header" />
        ) : (
          <>
            {title && <h3 class="text-lg font-semibold text-neutral-900">{title}</h3>}
            {subtitle && <p class="mt-1 text-sm text-neutral-600">{subtitle}</p>}
          </>
        )}
      </div>
    )
  }

  <div class="spectre-card__content">
    <slot />
  </div>

  {
    Astro.slots.has("footer") && (
      <div class="spectre-card__footer mt-4 border-t border-neutral-200 pt-4">
        <slot name="footer" />
      </div>
    )
  }
</div>
