{
  "name": "@phcdevworks/spectre-ui",
  "version": "1.1.0",
  "description": "Layer 2 of the Spectre suite: framework-agnostic UI primitives, recipes, and CSS built on Spectre tokens.",
  "keywords": [
    "phcdevworks",
    "spectre",
    "spectre-ui",
    "design-system",
    "design-tokens",
    "component-library",
    "ui-library",
    "ui-components",
    "tailwindcss",
    "css-utilities",
    "css-framework",
    "tokens",
    "utilities"
  ],
  "author": "PHCDevworks",
  "license": "MIT",
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/phcdevworks"
    },
    {
      "type": "buymeacoffee",
      "url": "https://buymeacoffee.com/phcdevworks"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/phcdevworks/spectre-ui.git"
  },
  "bugs": {
    "url": "https://github.com/phcdevworks/spectre-ui/issues"
  },
  "homepage": "https://github.com/phcdevworks/spectre-ui#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tailwind": {
      "types": "./dist/tailwind/index.d.ts",
      "import": "./dist/tailwind/index.js",
      "require": "./dist/tailwind/index.cjs"
    },
    "./index.css": "./dist/index.css",
    "./base.css": "./dist/base.css",
    "./components.css": "./dist/components.css",
    "./utilities.css": "./dist/utilities.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup --config tsup.config.ts && npm run build:css",
    "build:css": "mkdir -p dist && postcss src/styles/index.css -o dist/index.css",
    "dev": "tsup --config tsup.config.ts --watch",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "tailwindcss": "^3.4.0 || ^4.0.0"
  },
  "dependencies": {
    "@phcdevworks/spectre-tokens": "^2.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^10.1.0",
    "postcss": "^8.4.35",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.15",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.0.15"
  },
  "cSpell.words": [
    "phcdevworks"
  ]
}
