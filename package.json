{
  "name": "spectre-ui",
  "version": "0.0.1",
  "description": "CRO-optimized UI components for Astro + Tailwind v4. Built for marketers, designed for conversions.",
  "private": false,
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./components/*": "./dist/components/*",
    "./css": "./dist/styles/base.css",
    "./styles/*": "./dist/styles/*",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md",
    "ARCHITECTURE.md",
    "QUICKSTART.md"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "format": "prettier --cache --write .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "keywords": [
    "astro",
    "astro-integration",
    "astro-components",
    "ui",
    "design-system",
    "cro",
    "conversion",
    "marketing",
    "landing-page",
    "tailwindcss",
    "tailwind-v4",
    "typescript",
    "analytics"
  ],
  "peerDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "astro": "^4.0.0 || ^5.0.0",
    "tailwindcss": "^4.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^20.19.24",
    "astro": "^5.14.1",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.3.1",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "tailwindcss": "^4.1.14",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.45.0"
  },
  "engines": {
    "node": ">=18.17.1"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/phcdevworks/spectre-ui"
  },
  "bugs": {
    "url": "https://github.com/phcdevworks/spectre-ui/issues"
  },
  "homepage": "https://github.com/phcdevworks/spectre-ui#readme",
  "sideEffects": [
    "**/*.css",
    "**/*.astro"
  ]
}
