{
  "name": "@phcdevworks/spectre-ui",
  "version": "1.5.0",
  "description": "@phcdevworks/spectre-ui is the implementation layer between @phcdevworks/spectre-tokens and downstream adapters or apps.",
  "keywords": [
    "phcdevworks",
    "spectre",
    "spectre-ui",
    "design-system",
    "design-tokens",
    "component-library",
    "ui-library",
    "ui-components",
    "tailwindcss",
    "css-utilities",
    "css-framework",
    "tokens",
    "utilities"
  ],
  "author": "PHCDevworks",
  "license": "MIT",
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/phcdevworks"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/phcdevworks/spectre-ui.git"
  },
  "bugs": {
    "url": "https://github.com/phcdevworks/spectre-ui/issues"
  },
  "homepage": "https://github.com/phcdevworks/spectre-ui#readme",
  "engines": {
    "node": "^22.12.0 || >=24.0.0"
  },
  "type": "module",
  "packageManager": "npm@11.13.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tailwind": {
      "types": "./dist/tailwind/index.d.ts",
      "import": "./dist/tailwind/index.js",
      "require": "./dist/tailwind/index.cjs"
    },
    "./index.css": "./dist/index.css",
    "./base.css": "./dist/base.css",
    "./components.css": "./dist/components.css",
    "./utilities.css": "./dist/utilities.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "./dist/index.css",
    "./dist/base.css",
    "./dist/components.css",
    "./dist/utilities.css"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts && npm run build:css",
    "build:css": "node ./scripts/build-css.mjs",
    "ci:verify": "npm run validate:runtime && npm run lint && npm run validate:exports && npm run validate:readme && npm run validate:tokens && npm run build && npm run validate:tailwind && npm run validate:css-contract && npm test",
    "dev": "tsup --config tsup.config.ts --watch",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "pretest": "npm run build",
    "format": "prettier --write .",
    "test": "vitest run",
    "validate:css-contract": "node ./scripts/validate-css-contract.mjs",
    "validate:exports": "node ./scripts/validate-exports.mjs",
    "validate:exports:update": "node ./scripts/validate-exports.mjs --update",
    "validate:runtime": "node ./scripts/validate-runtime.mjs",
    "validate:tailwind": "node ./scripts/validate-tailwind-contract.mjs",
    "validate:tailwind:update": "node ./scripts/validate-tailwind-contract.mjs --update",
    "validate:readme": "node ./scripts/validate-readme-contract.mjs",
    "validate:tokens": "node ./scripts/validate-tokens.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "tailwindcss": "^3.4.0 || ^4.0.0",
    "typescript": "^5.9 || ^6.0"
  },
  "dependencies": {
    "@phcdevworks/spectre-tokens": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "jiti": "^2.6.1",
    "postcss": "^8.5.13",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "cSpell.words": [
    "phcdevworks"
  ]
}
