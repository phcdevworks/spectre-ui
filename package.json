{
  "name": "@phcdevworks/spectre-ui",
  "version": "2.8.0",
  "description": "@phcdevworks/spectre-ui is the styling contract package of the Spectre system. It translates Spectre design tokens into CSS bundles, Tailwind theme configuration, and class recipe functions for downstream adapters and apps.",
  "keywords": [
    "phcdevworks",
    "spectre",
    "spectre-ui",
    "design-system",
    "design-tokens",
    "class-recipes",
    "css-bundles",
    "css-utilities",
    "css-framework",
    "tailwindcss",
    "tailwind-preset",
    "tokens",
    "utilities"
  ],
  "author": "PHCDevworks",
  "license": "MIT",
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/phcdevworks"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/phcdevworks/spectre-ui.git"
  },
  "bugs": {
    "url": "https://github.com/phcdevworks/spectre-ui/issues"
  },
  "homepage": "https://github.com/phcdevworks/spectre-ui#readme",
  "engines": {
    "node": "^22.13.0 || >=24.0.0",
    "npm": ">=10.0.0"
  },
  "type": "module",
  "packageManager": "npm@12.0.1",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tailwind": {
      "types": "./dist/tailwind/index.d.ts",
      "import": "./dist/tailwind/index.js",
      "require": "./dist/tailwind/index.cjs"
    },
    "./index.css": "./dist/index.css",
    "./base.css": "./dist/base.css",
    "./components.css": "./dist/components.css",
    "./utilities.css": "./dist/utilities.css"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": [
    "./dist/index.css",
    "./dist/base.css",
    "./dist/components.css",
    "./dist/utilities.css"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts && npm run build:css",
    "build:css": "node --experimental-strip-types ./scripts/build-css.ts",
    "check": "npm run ci:verify && npm run check:ecosystem",
    "ci:verify": "npm run validate:runtime && npm run lint && npm run validate:changelog && npm run validate:exports && npm run validate:readme && npm run validate:tokens && npm run build && npm run validate:tailwind && npm run validate:css-contract && npm test",
    "dev": "tsup --config tsup.config.ts --watch",
    "clean": "rm -rf dist",
    "release:propose": "node --experimental-strip-types ./scripts/propose-version.ts",
    "lint": "eslint .",
    "pretest": "npm run build",
    "format": "prettier --write .",
    "test": "vitest run",
    "validate:css-contract": "node --experimental-strip-types ./scripts/validate-css-contract.ts",
    "validate:exports": "node --experimental-strip-types ./scripts/validate-exports.ts",
    "validate:exports:update": "node --experimental-strip-types ./scripts/validate-exports.ts --update",
    "validate:runtime": "node --experimental-strip-types ./scripts/validate-runtime.ts",
    "validate:tailwind": "node --experimental-strip-types ./scripts/validate-tailwind-contract.ts",
    "validate:tailwind:update": "node --experimental-strip-types ./scripts/validate-tailwind-contract.ts --update",
    "validate:readme": "node --experimental-strip-types ./scripts/validate-readme-contract.ts",
    "check:version-sync": "npm run validate:readme",
    "validate:changelog": "node --experimental-strip-types ./scripts/validate-changelog.ts",
    "validate:tokens": "node --experimental-strip-types ./scripts/validate-tokens.ts",
    "check:ecosystem": "spectre-manifest-validate spectre.manifest.json && spectre-manifest-check spectre.manifest.json ."
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "tailwindcss": "^3.4.0 || ^4.0.0",
    "typescript": "^5.9 || ^6.0"
  },
  "dependencies": {
    "@phcdevworks/spectre-tokens": "^3.3.1"
  },
  "devDependencies": {
    "@phcdevworks/spectre-manifest": "^1.1.0",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "autoprefixer": "^10.5.2",
    "eslint": "^10.7.0",
    "jiti": "^2.7.0",
    "postcss": "^8.5.19",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "cSpell.words": [
    "phcdevworks"
  ],
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
