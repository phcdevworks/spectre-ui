{
  "version": "2.6.0",
  "cssEntrypoints": [
    "@phcdevworks/spectre-ui/index.css",
    "@phcdevworks/spectre-ui/base.css",
    "@phcdevworks/spectre-ui/components.css",
    "@phcdevworks/spectre-ui/utilities.css"
  ],
  "rootExports": {
    "constants": [
      "spectreStyles",
      "spectreBaseStylesPath",
      "spectreComponentsStylesPath",
      "spectreIndexStylesPath",
      "spectreUtilitiesStylesPath"
    ],
    "functions": [
      "getAlertClasses",
      "getAvatarClasses",
      "getBadgeClasses",
      "getButtonClasses",
      "getCardClasses",
      "getCheckboxClasses",
      "getDropdownClasses",
      "getDropdownItemClasses",
      "getDropdownMenuClasses",
      "getFieldsetClasses",
      "getFieldsetLegendClasses",
      "getIconBoxClasses",
      "getInputClasses",
      "getInputErrorMessageClasses",
      "getInputHelperTextClasses",
      "getInputLabelClasses",
      "getInputWrapperClasses",
      "getContainerClasses",
      "getFooterClasses",
      "getGridClasses",
      "getLabelClasses",
      "getModalClasses",
      "getModalOverlayClasses",
      "getNavClasses",
      "getNavLinkClasses",
      "getNavLinksClasses",
      "getPricingCardBadgeClasses",
      "getPricingCardClasses",
      "getPricingCardDescriptionClasses",
      "getPricingCardPriceClasses",
      "getPricingCardPriceContainerClasses",
      "getRadioClasses",
      "getRatingClasses",
      "getRatingStarClasses",
      "getRatingStarsClasses",
      "getRatingTextClasses",
      "getSectionClasses",
      "getSelectClasses",
      "getSidebarBackdropClasses",
      "getSidebarClasses",
      "getSidebarHeaderClasses",
      "getSidebarLinkClasses",
      "getSpinnerClasses",
      "getStackClasses",
      "getTagClasses",
      "getTextareaClasses",
      "getTestimonialAuthorClasses",
      "getTestimonialAuthorInfoClasses",
      "getTestimonialAuthorNameClasses",
      "getTestimonialAuthorTitleClasses",
      "getTestimonialClasses",
      "getTestimonialQuoteClasses",
      "getToastClasses",
      "getToastIconClasses",
      "getTooltipClasses"
    ]
  },
  "tailwindExports": [
    "createSpectreTailwindPreset",
    "createSpectreTailwindTheme"
  ],
  "recipeFamilies": {
    "button": {
      "fn": "getButtonClasses",
      "variants": ["primary", "secondary", "ghost", "danger", "success", "cta", "accent"],
      "sizes": ["sm", "md", "lg"]
    },
    "badge": {
      "fn": "getBadgeClasses",
      "variants": ["primary", "secondary", "success", "warning", "danger", "neutral", "info", "ghost", "accent", "cta"],
      "sizes": ["sm", "md", "lg"]
    },
    "card": {
      "fn": "getCardClasses",
      "variants": ["elevated", "flat", "outline", "ghost"]
    },
    "input": {
      "fn": "getInputClasses",
      "states": ["default", "error", "success", "disabled", "loading"],
      "sizes": ["sm", "md", "lg"]
    },
    "iconbox": {
      "fn": "getIconBoxClasses",
      "variants": ["primary", "secondary", "success", "warning", "danger", "info", "neutral", "ghost", "accent", "cta"],
      "sizes": ["sm", "md", "lg"]
    },
    "pricingCard": {
      "fn": "getPricingCardClasses"
    },
    "testimonial": {
      "fn": "getTestimonialClasses",
      "variants": ["elevated", "flat", "outline", "ghost"]
    },
    "rating": {
      "fn": "getRatingClasses",
      "sizes": ["sm", "md", "lg"]
    },
    "alert": {
      "fn": "getAlertClasses",
      "variants": ["info", "success", "warning", "danger", "neutral"],
      "sizes": ["sm", "md", "lg"]
    },
    "avatar": {
      "fn": "getAvatarClasses",
      "sizes": ["xs", "sm", "md", "lg", "xl"]
    },
    "tag": {
      "fn": "getTagClasses",
      "variants": ["default", "primary", "secondary", "success", "warning", "danger", "info", "neutral", "accent", "cta", "outline", "ghost"],
      "sizes": ["sm", "md", "lg"]
    },
    "spinner": {
      "fn": "getSpinnerClasses",
      "variants": ["primary", "secondary", "success", "warning", "danger", "info", "neutral", "accent", "cta"],
      "sizes": ["sm", "md", "lg"]
    },
    "nav": {
      "fn": "getNavClasses"
    },
    "toast": {
      "fn": "getToastClasses",
      "variants": ["info", "success", "warning", "danger"]
    },
    "tooltip": {
      "fn": "getTooltipClasses"
    },
    "dropdown": {
      "fn": "getDropdownClasses"
    },
    "modal": {
      "fn": "getModalClasses"
    },
    "container": {
      "fn": "getContainerClasses"
    },
    "stack": {
      "fn": "getStackClasses"
    },
    "section": {
      "fn": "getSectionClasses"
    },
    "grid": {
      "fn": "getGridClasses"
    },
    "sidebar": {
      "fn": "getSidebarClasses"
    },
    "footer": {
      "fn": "getFooterClasses"
    },
    "checkbox": {
      "fn": "getCheckboxClasses"
    },
    "radio": {
      "fn": "getRadioClasses"
    },
    "select": {
      "fn": "getSelectClasses"
    },
    "textarea": {
      "fn": "getTextareaClasses"
    },
    "fieldset": {
      "fn": "getFieldsetClasses"
    },
    "label": {
      "fn": "getLabelClasses"
    }
  }
}
